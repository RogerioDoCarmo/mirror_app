{
  "expo": {
    "name": "Miroji",
    "slug": "mirror-app",
    "version": "1.2.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mirrorapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#80BBFC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rogeriodocarmo.miroji",
      "infoPlist": {
        "NSCameraUsageDescription": "Miroji uses your front camera to show you a mirror view.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "appleTeamId": "X37R283V2T"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.rogeriodocarmo.miroji",
      "permissions": ["android.permission.CAMERA"],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Miroji uses your front camera to display a mirror view.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "fb2332e5-c3f1-4016-b1ff-021e58211658"
      }
    },
    "owner": "rogeriodocarmo"
  }
}
