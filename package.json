{
  "name": "mirror-app",
  "version": "1.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "run:android": "expo run:android --device",
    "run:ios": "expo run:ios --device",
    "build:apk": "eas build --platform android --profile preview",
    "build:ipa": "eas build --platform ios --profile production",
    "test:e2e": "maestro test .maestro/flows/",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --forceExit",
    "mutation": "stryker run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --clear"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.3",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "~6.0.21",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-safe-area-context": "^5.8.0"
  },
  "devDependencies": {
    "@storybook/addon-ondevice-actions": "^10.4.4",
    "@storybook/addon-ondevice-backgrounds": "^10.4.4",
    "@storybook/addon-ondevice-controls": "^10.4.4",
    "@storybook/addon-ondevice-notes": "^10.4.4",
    "@storybook/react-native": "^10.4.4",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jest-expo": "^54.0.17",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.3"
  },
  "private": true
}
